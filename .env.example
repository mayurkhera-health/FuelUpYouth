# ─────────────────────────────────────────────────────────────────────────────
# FuelUp backend — local environment template
#
# Usage:   cp .env.example .env   then fill in the secret values below.
# `api/main.py` calls load_dotenv(), so `.env` is auto-loaded when you run
# `uvicorn api.main:app --reload --port 8000` — no extra step.
#
# `.env` is gitignored. Keep real secrets OUT of this committed template.
# The FEATURE FLAGS below are set to PROD-MATCHING values on purpose, so local
# exercises the same code paths prod does (this is what prevents "works/broken
# locally but the opposite in prod" surprises).
# ─────────────────────────────────────────────────────────────────────────────

# ── Feature flags (match prod — verified via `fly secrets`) ───────────────────
# Prod has all three of these ON. Leaving them unset/false makes local run a
# DIFFERENT engine than prod (e.g. the legacy clock-based window engine).
EVENT_RELATIVE_WINDOWS=true   # ON in prod -> event-relative window_engine_v2. OFF -> legacy window_templates engine.
FUEL_GAUGE_ENABLED=true       # ON in prod -> fuel-gauge / fueling_targets logic.
COACH_WEB_SEARCH_ENABLED=true # ON in prod -> Nutrition Coach live web search (approved domains only).

# ── Local-only behavior flag (intentionally NOT prod's value) ─────────────────
# Prod = false (sends real Web Push). Locally keep it TRUE so testing does not
# fire real notifications to devices. This is a side-effect flag — it does not
# change the windows/labels/UI you're verifying, only whether pushes are sent.
NOTIFICATION_DRY_RUN=true

# ── Secrets — fill in locally; never commit real values ───────────────────────
SECRET_KEY=                   # app secret (session signing)
ANTHROPIC_API_KEY=            # Claude (coach copy generation, claude-sonnet-4-6)
OPENWEATHERMAP_API_KEY=       # weather -> sweat/hydration estimates
FDC_API_KEY=                  # USDA FoodData Central. Key signup: https://fdc.nal.usda.gov/api-key-signup

# Web Push (VAPID) — only needed if testing real notifications locally
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=

# Outbound email (dietitian replies / problem reports) — optional locally
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── AWS Bedrock (RAG knowledge base + embeddings) ─────────────────────────────
# Default credential chain: env vars, ~/.aws/credentials, or IAM role on Fly.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=mistral.ministral-3-8b-instruct
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_KB_ID=                # Bedrock Knowledge Base id (RAG retrieval)

# ── Database ──────────────────────────────────────────────────────────────────
# Prod uses the Fly volume path /data/fuelup.db. Locally a repo-relative file is
# fine. Run `python db/setup.py` once after setting this.
DB_PATH=fuelup.db
